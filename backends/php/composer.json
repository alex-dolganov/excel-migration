{
    "name": "bitrix24/starter-kit-php-backend",
    "version": "0.0.1",
    "minimum-stability": "dev",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "darsyn/ip": "^6",
        "darsyn/ip-doctrine": "^6.0.1",
        "doctrine/dbal": "^4.5",
        "doctrine/doctrine-bundle": "^3.3.0",
        "doctrine/doctrine-migrations-bundle": "^4.0",
        "doctrine/orm": "^3.7.0",
        "firebase/php-jwt": "dev-main",
        "giggsey/libphonenumber-for-php": "^8.13.55",
        "mesilov/bitrix24-php-lib": "^0.5.2",
        "nelmio/cors-bundle": "^2.0@dev",
        "nesbot/carbon": "^3",
        "nyholm/psr7": ">=1.8",
        "odolbeau/phone-number-bundle": "^4.1",
        "open-telemetry/exporter-otlp": "^1.4",
        "open-telemetry/sdk": "^1.14",
        "symfony/console": "7.4.*",
        "symfony/dotenv": "7.4.*",
        "symfony/flex": "^2",
        "symfony/framework-bundle": "7.4.*",
        "symfony/monolog-bundle": "^3",
        "symfony/runtime": "7.4.*",
        "symfony/yaml": "7.4.*"
    },
    "require-dev": {
        "roave/security-advisories": "dev-latest",
        "symfony/maker-bundle": "^1",
        "phpstan/phpstan": "^1.12",
        "rector/rector": "^1.2.10",
        "friendsofphp/php-cs-fixer": "^3.95.2",
        "phpunit/phpunit": "^11.5",
        "symfony/browser-kit": "7.4.*"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true,
            "tbachert/spi": true
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.4.*",
            "docker": true
        }
    }
}
